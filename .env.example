# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_API_BASE_URL=https://api.openai.com/v1

# GitHub App (https://github.com/settings/apps)
GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=your_webhook_secret
# PEM content with \n escaped, or mount a file and set path:
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_PRIVATE_KEY_PATH=
GITHUB_APP_SLUG=patchwork-ai
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# URLs
PUBLIC_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Prompt
ACTIVE_PROMPT_VERSION=v2

# Redis / DB (defaults work with docker-compose)
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite+aiosqlite:///./patchwork.db
